# ── FastAPI backend URL (server-side only, never sent to the browser) ─────────
#
# The Next.js /api/chat route proxies all chat requests to this address.
# Set this to wherever your FastAPI process is listening.
#
# Local development (default if unset):
FASTAPI_URL=http://localhost:8000
#
# Docker Compose example (service name as hostname):
# FASTAPI_URL=http://backend:8000
#
# Production:
# FASTAPI_URL=https://api.yourdomain.com


# ── Optional: skip the proxy and call FastAPI directly from the browser ───────
#
# Only set this if you want the browser to hit FastAPI directly instead of
# going through the Next.js proxy.  Requires CORS to be configured on FastAPI.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
