# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: OpenAI API key (used for embeddings + chat completion)
OPENAI_API_KEY=sk-...

# Optional: Override the model (default: gpt-3.5-turbo)
# OPENAI_MODEL=gpt-4o

# Optional: Flask secret key for session signing
# FLASK_SECRET_KEY=change-me-in-production

