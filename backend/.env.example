# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: OpenAI API key (used for embeddings + chat completion)
OPENAI_API_KEY=sk-...

# Optional: Override the chat model used for answers
# OPENAI_MODEL=gpt-4o-mini

# Optional: Override the embedding model used for retrieval.
# text-embedding-3-small is newer and lower-cost than text-embedding-ada-002.
# Re-run ingestion after changing this.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Flask secret key for session signing
# FLASK_SECRET_KEY=change-me-in-production

