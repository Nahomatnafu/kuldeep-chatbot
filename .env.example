# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env to version control — it's in .gitignore

# ════════════════════════════════════════════════════════════════════════════════
# REQUIRED: OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
# ════════════════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=sk-YOUR_ACTUAL_API_KEY_HERE

# ════════════════════════════════════════════════════════════════════════════════
# OPTIONAL: Flask backend URL (used by Next.js route handlers)
# Default: http://localhost:5000 (local development)
# For Docker: http://backend:5000 (service name on Docker network)
# For production: https://api.yourdomain.com
# ════════════════════════════════════════════════════════════════════════════════
# FLASK_URL=http://localhost:5000

# ════════════════════════════════════════════════════════════════════════════════
# OPTIONAL: OpenAI Whisper model for voice transcription
# Default: whisper-1
# ════════════════════════════════════════════════════════════════════════════════
# OPENAI_TRANSCRIBE_MODEL=whisper-1
