# ── Flask backend URL (server-side only, never sent to the browser) ──────────
#
# The Next.js /api/chat route proxies all chat requests to this address.
# Set this to wherever your Flask process is listening.
#
# Local development (default if unset):
FLASK_URL=http://localhost:5000
#
# Docker Compose example (service name as hostname):
# FLASK_URL=http://backend:5000
#
# Production:
# FLASK_URL=https://api.yourdomain.com
